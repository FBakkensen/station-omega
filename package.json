{
  "name": "station-omega",
  "version": "1.0.0",
  "description": "Station Omega web app with shared game engine and Convex backend",
  "type": "module",
  "scripts": {
    "dev": "bunx concurrently -k -n CONVEX,WEB -c cyan,magenta \"bun run dev:convex\" \"bun run dev:web\"",
    "dev:web": "bun run --cwd web dev",
    "dev:convex": "bunx convex dev",
    "typecheck": "tsc --noEmit",
    "typecheck:convex": "bunx tsc --noEmit -p convex/tsconfig.json",
    "typecheck:web": "bun run --cwd web typecheck",
    "lint": "eslint .",
    "lint:web": "bun run --cwd web lint",
    "deadcode": "knip",
    "build:web": "bun run --cwd web build",
    "ai-logs": "bun scripts/ai-logs.ts",
    "cleanup:legacy-games": "bun scripts/purge-legacy-games.ts",
    "cleanup:legacy-games:apply": "bun scripts/purge-legacy-games.ts --apply",
    "pw": "playwright-cli",
    "pw:snapshot": "bash ./scripts/pw-snapshot.sh",
    "pw:install": "playwright-cli install",
    "test:fixture": "bun test/generate-fixture.ts",
    "test:creative": "bun test/test-creative.ts",
    "test:gm": "bun test/test-gamemaster.ts",
    "test:analyze": "bun test/analyze-results.ts",
    "test:det": "vitest run",
    "test:det:watch": "vitest",
    "test:det:coverage": "vitest run --coverage",
    "test:web": "bun run --cwd web test",
    "test:zombies": "bun test/zombies-audit.ts",
    "check:static": "bun run typecheck && bun run typecheck:convex && bun run lint && bun run deadcode && bun run typecheck:web && bun run lint:web",
    "check:tests": "bun run test:zombies && bun run test:det && bun run test:web",
    "qa": "bun run check:static && bun run check:tests",
    "check": "bun run qa"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "ai": "^6.0.86",
    "convex": "^1.32.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@playwright/cli": "^0.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@types/node": "^25.2.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "knip": "^5.63.1",
    "vitest": "^3.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "trustedDependencies": []
}
